# Copier vers .env :   copy .env.example .env   puis adaptez les valeurs.

FLASK_SECRET_KEY=changez-moi-en-production-long-et-aleatoire

# Stripe (optionnel) — https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

# --- Virement (page paiement après choix « Virement ») ---
# Renseignez au minimum BANK_IBAN pour afficher le RIB au client.
# Exemple de format (RIB fictif, à remplacer par le vôtre) :
BANK_NAME=Banque à préciser
BANK_HOLDER=YOMBAL MARCHE
BANK_IBAN=FR76 3000 6000 0112 3456 7890 189
BANK_BIC=AGRIFRPPXXX

# Utilisé dans les messages si le RIB n’est pas encore configuré
CONTACT_EMAIL=contact@yombal-marche.local

# PayPal — après choix « PayPal » sur la page paiement
# Mettez l’e-mail du compte qui reçoit les virements PayPal (au minimum).
PAYPAL_EMAIL=
# Exemple : https://paypal.me/moncommerce
PAYPAL_ME_URL=

# --- Webhook Stripe (paiement confirmé même si le client ferme le navigateur) ---
# Dashboard Stripe → Développeurs → Webhooks → endpoint POST https://votre-domaine/webhooks/stripe
STRIPE_WEBHOOK_SECRET=

# --- Back-office commandes : e-mails autorisés (séparés par des virgules), identiques aux comptes clients ---
ADMIN_EMAILS=

# --- E-mails transactionnels (SMTP). Sans MAIL_SERVER : les mails sont seulement journalisés dans la console. ---
MAIL_SERVER=
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=
# MAIL_SUPPRESS_SEND=true
