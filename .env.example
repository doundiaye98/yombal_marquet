# =============================================================================
# VARIABLES D’ENVIRONNEMENT — local (.env) ou hébergeur (ex. Render → Environment)
# =============================================================================
# En local : copiez ce fichier vers .env puis adaptez.
# Migrations DB : FLASK_APP=app.py puis `flask db upgrade` (ou python scripts/init_db.py)
# =============================================================================

# --- Flask ---
FLASK_APP=app.py

# --- Obligatoire en production ---
# Clé secrète Flask (sessions, flash). Générez une longue chaîne aléatoire.
FLASK_SECRET_KEY=changez-moi-en-production-long-et-aleatoire

# --- Base de données (Render / hébergeur) ---
# Si vous créez une base PostgreSQL sur Render et que vous la liez au Web Service,
# Render remplit automatiquement DATABASE_URL (ne pas la committer).
# Sans DATABASE_URL : l’app utilise SQLite dans instance/ (OK en dev, fragile sur Render).
# DATABASE_URL=

# -----------------------------------------------------------------------------
# Paiement Stripe — https://dashboard.stripe.com/apikeys
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

# Webhook : URL HTTPS du site + /webhooks/stripe — secret « Signing secret » Stripe
STRIPE_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Virement & contact (page paiement, messages clients)
# -----------------------------------------------------------------------------
BANK_NAME=
BANK_HOLDER=
BANK_IBAN=
BANK_BIC=
CONTACT_EMAIL=compta@universdiasporas.com

# -----------------------------------------------------------------------------
# PayPal (instructions après choix PayPal sur la page paiement)
# -----------------------------------------------------------------------------
PAYPAL_EMAIL=
PAYPAL_ME_URL=

# -----------------------------------------------------------------------------
# Administration boutique — e-mails autorisés (séparés par des virgules).
# Doivent correspondre à des comptes créés via scripts/create_admin.py ou BOOTSTRAP_ADMIN_PASSWORD
ADMIN_EMAILS=compta@universdiasporas.com

# Render / premier déploiement : crée les comptes ADMIN_EMAILS en base Postgres au démarrage
# Supprimez cette variable après la première connexion réussie (sécurité)
BOOTSTRAP_ADMIN_PASSWORD=

# -----------------------------------------------------------------------------
# Production — désactiver la simulation de paiement (obligatoire en prod)
# -----------------------------------------------------------------------------
PAYMENT_SIMULATION=0

# -----------------------------------------------------------------------------
# Images produits (Render) — Cloudinary pour uploads admin persistants
# https://cloudinary.com/console
# -----------------------------------------------------------------------------
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
# CLOUDINARY_FOLDER=yombal/products

# -----------------------------------------------------------------------------
# E-mails SMTP (commandes / paiements). Sans MAIL_SERVER → log console uniquement.
# -----------------------------------------------------------------------------
MAIL_SERVER=
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=
# Mettre à true pour forcer la simulation (aucun envoi réel)
# MAIL_SUPPRESS_SEND=true

# -----------------------------------------------------------------------------
# SMS — Africa's Talking (recommandé Sénégal/Afrique) ou Twilio
# -----------------------------------------------------------------------------
# Fournisseur : auto | africastalking | twilio | none
SMS_PROVIDER=auto
SMS_DEFAULT_COUNTRY=SN

# Africa's Talking — https://account.africastalking.com (sandbox : username = sandbox)
AFRICASTALKING_API_KEY=
AFRICASTALKING_USERNAME=sandbox
AFRICASTALKING_SANDBOX=true
# Expéditeur alphanumérique (prod) ou laisser vide en sandbox
AFRICASTALKING_SENDER_ID=

# Twilio (alternative)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
# SMS_SUPPRESS_SEND=true
