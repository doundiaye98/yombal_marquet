# =============================================================================
# VARIABLES D’ENVIRONNEMENT — local (.env) ou hébergeur (ex. Render → Environment)
# =============================================================================
# En local : copiez ce fichier vers .env puis adaptez.
# Migrations DB : FLASK_APP=app.py puis `flask db upgrade` (ou python scripts/init_db.py)
# =============================================================================

# --- Flask ---
FLASK_APP=app.py

# --- Obligatoire en production ---
# Clé secrète Flask (sessions, flash). Générez une longue chaîne aléatoire.
FLASK_SECRET_KEY=changez-moi-en-production-long-et-aleatoire

# --- Base de données (Render / hébergeur) ---
# Si vous créez une base PostgreSQL sur Render et que vous la liez au Web Service,
# Render remplit automatiquement DATABASE_URL (ne pas la committer).
# Sans DATABASE_URL : l’app utilise SQLite dans instance/ (OK en dev, fragile sur Render).
# DATABASE_URL=

# -----------------------------------------------------------------------------
# Paiement Stripe — https://dashboard.stripe.com/apikeys
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

# Webhook : URL HTTPS du site + /webhooks/stripe — secret « Signing secret » Stripe
STRIPE_WEBHOOK_SECRET=

# -----------------------------------------------------------------------------
# Virement & contact (page paiement, messages clients)
# -----------------------------------------------------------------------------
BANK_NAME=
BANK_HOLDER=
BANK_IBAN=
BANK_BIC=
CONTACT_EMAIL=contact@exemple.com

# -----------------------------------------------------------------------------
# PayPal (instructions après choix PayPal sur la page paiement)
# -----------------------------------------------------------------------------
PAYPAL_EMAIL=
PAYPAL_ME_URL=

# -----------------------------------------------------------------------------
# Administration boutique — e-mails autorisés (séparés par des virgules).
# Doivent correspondre à des comptes déjà inscrits sur le site.
# -----------------------------------------------------------------------------
ADMIN_EMAILS=

# -----------------------------------------------------------------------------
# E-mails SMTP (commandes / paiements). Sans MAIL_SERVER → log console uniquement.
# -----------------------------------------------------------------------------
MAIL_SERVER=
MAIL_PORT=587
MAIL_USE_TLS=true
MAIL_USERNAME=
MAIL_PASSWORD=
MAIL_DEFAULT_SENDER=
# Mettre à true pour forcer la simulation (aucun envoi réel)
# MAIL_SUPPRESS_SEND=true
